---
interface Props {
  title: string;
  modalities?: string;
  duration: string;
  rate: string;
  description?: string;
}

const { title, modalities, duration, rate, description } = Astro.props;
---

<div class="bg-cream border border-sand rounded-2xl p-8 flex flex-col gap-4 hover:shadow-md transition-shadow duration-200">
  <h3 class="font-serif text-forest text-2xl font-medium">{title}</h3>
  {description && (
    <p class="font-sans text-slate text-sm leading-relaxed">{description}</p>
  )}
  {modalities && (
    <p class="font-sans text-muted text-xs tracking-wide uppercase">{modalities}</p>
  )}
  <div class="flex flex-wrap gap-6 mt-2 border-t border-sand pt-4">
    <div>
      <p class="font-sans text-xs text-muted uppercase tracking-wide mb-1">Duration</p>
      <p class="font-serif text-forest text-base font-medium">{duration}</p>
    </div>
    <div>
      <p class="font-sans text-xs text-muted uppercase tracking-wide mb-1">Rate</p>
      <p class="font-serif text-forest text-base font-medium">{rate}</p>
    </div>
  </div>
</div>
