---
import Leaf from './icons/Leaf.astro';

interface Props {
  title: string;
  modalities?: string;
  duration: string;
  rate: string;
  description?: string;
}

const { title, modalities, duration, rate, description } = Astro.props;
---

<div style="border-top: 0.5px solid var(--color-mid); padding: 2rem 0;">
  <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2rem; align-items: start;" class="card-grid">

    <div>
      <h3 style="font-family: var(--font-display); font-size: 1.3rem; font-weight: 500; color: var(--color-ink); margin-bottom: 0.6rem; display: flex; align-items: center; gap: 0.5rem;">
        <span style="color: var(--color-mid); opacity: 0.7; flex-shrink: 0;"><Leaf size={14} /></span>
        {title}
      </h3>
      {description && (
        <p style="font-family: var(--font-body); font-size: 0.9rem; line-height: 1.7; color: var(--color-stone);">{description}</p>
      )}
      {modalities && (
        <p class="section-label" style="margin-top: 0.75rem;">{modalities}</p>
      )}
    </div>

    <div>
      <p class="section-label" style="margin-bottom: 0.3rem;">Duration</p>
      <p style="font-family: var(--font-display); font-size: 1rem; color: var(--color-mid);">{duration}</p>
    </div>

    <div>
      <p class="section-label" style="margin-bottom: 0.3rem;">Rate</p>
      <p style="font-family: var(--font-display); font-size: 1rem; color: var(--color-mid);">{rate}</p>
    </div>

  </div>
</div>

<style>
  @media (max-width: 600px) {
    .card-grid {
      grid-template-columns: 1fr !important;
      gap: 1rem !important;
    }
  }
</style>
