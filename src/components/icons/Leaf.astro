---
interface Props {
  size?: number;
  class?: string;
}
const { size = 16, class: cls = '' } = Astro.props;
// Leaf.svg is landscape (110×93.9), so width > height
const w = Math.round(size * 1.17);
---
<img
  src="/leaf.svg"
  width={w}
  height={size}
  class={cls}
  aria-hidden="true"
  style="flex-shrink:0; display:inline-block;"
  alt=""
/>
