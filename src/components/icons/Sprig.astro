---
interface Props {
  size?: number;
  class?: string;
}
const { size = 28, class: cls = '' } = Astro.props;
// plant.svg viewBox 83×105 → aspect ~0.79:1
const w = Math.round(size * 0.79);
---
<img
  src="/plant.svg"
  width={w}
  height={size}
  class={cls}
  aria-hidden="true"
  style="flex-shrink:0; display:inline-block;"
  alt=""
/>
