---
---

<!-- Editorial asymmetric hero — paper bg, no full-bleed color wash -->
<section style="background: var(--color-paper); border-bottom: 0.5px solid var(--color-mid);">
  <div class="max-w-6xl mx-auto px-6 md:px-10">

    <!-- Main grid: headline left, botanical image right -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0; min-height: 520px;" class="hero-grid">

      <!-- Left: typographic content -->
      <div style="padding: 4rem 3rem 4rem 0; display: flex; flex-direction: column; justify-content: space-between; border-right: 0.5px solid var(--color-mid);">

        <div>
          <p class="section-label" style="margin-bottom: 2rem;">Philadelphia, PA · LCSW</p>

          <h1 style="font-family: var(--font-display); font-size: clamp(2.6rem, 5vw, 4.2rem); font-weight: 400; line-height: 1.08; color: var(--color-ink); margin-bottom: 1.75rem; font-style: italic;">
            Healing through<br />the body,<br /><em style="font-style: normal; font-weight: 600;">not just the mind.</em>
          </h1>

          <p style="font-family: var(--font-body); font-size: 1.05rem; line-height: 1.75; color: var(--color-stone); max-width: 38ch;">
            Somatic and EMDR psychotherapy for adults navigating trauma, anxiety, and life transitions.
          </p>
        </div>

        <div style="margin-top: 3rem;">
          <div class="rule" style="margin-bottom: 1.75rem;"></div>
          <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
            <a href="/contact" class="btn btn-filled" style="font-size: 0.75rem; letter-spacing: 0.1em;">
              Book Free Consultation
            </a>
            <a href="/about" style="font-family: var(--font-body); font-size: 0.85rem; color: var(--color-stone); letter-spacing: 0.04em; text-decoration: underline; text-underline-offset: 4px;">
              About River →
            </a>
          </div>
          <p style="font-family: var(--font-body); font-size: 0.78rem; color: var(--color-stone); margin-top: 0.85rem; letter-spacing: 0.02em;">
            20-minute consultation, no commitment
          </p>
        </div>

      </div>

      <!-- Right: botanical image placeholder — duotone ready -->
      <div style="position: relative;">
        <!-- PLACEHOLDER: Replace this div with <div class="botanical-wrapper"> containing <img class="botanical-img" src="..." alt="..."> -->
        <!-- Designer will supply high-contrast botanical photography (passionflower, honey locust spines, streams, leaves) -->
        <!-- CSS duotone treatment (grayscale + multiply blend) is already defined in global.css as .botanical-wrapper / .botanical-img -->
        <div
          class="botanical-placeholder"
          data-label="Botanical photography — duotone"
          style="width: 100%; height: 100%; min-height: 520px;"
        ></div>

        <!-- Overlaid section label, bottom-left of image -->
        <p class="section-label" style="position: absolute; bottom: 1.25rem; left: 1.25rem; opacity: 0.7;">
          Somatic · EMDR · Psychodynamic
        </p>
      </div>

    </div>

  </div>
</section>

<style>
  @media (max-width: 700px) {
    .hero-grid {
      grid-template-columns: 1fr !important;
    }
    .hero-grid > *:first-child {
      border-right: none !important;
      padding-right: 0 !important;
      padding-bottom: 2.5rem;
      border-bottom: 0.5px solid var(--color-mid);
    }
    .hero-grid > *:last-child {
      min-height: 300px !important;
    }
  }
</style>
