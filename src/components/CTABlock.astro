---
interface Props {
  heading?: string;
  body?: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  heading = 'Ready to take the next step?',
  body = 'Reach out to ask questions or schedule a free consultation.',
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
} = Astro.props;
---

<section class="bg-sand py-16 px-6 md:px-12 mt-16">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="font-serif text-forest text-3xl font-medium mb-4">{heading}</h2>
    <p class="font-sans text-slate text-base leading-relaxed mb-8">{body}</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href={primaryHref} class="btn-primary">{primaryLabel}</a>
      {secondaryLabel && secondaryHref && (
        <a href={secondaryHref} class="btn-secondary">{secondaryLabel}</a>
      )}
    </div>
  </div>
</section>
