---
import Sprig from './icons/Sprig.astro';

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header style="background: var(--color-paper); border-bottom: 0.5px solid var(--color-mid);">
  <nav class="max-w-6xl mx-auto px-6 md:px-10" style="display: flex; align-items: center; justify-content: space-between; padding-top: 1.1rem; padding-bottom: 1.1rem; gap: 2rem;">

    <a href="/" style="display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-display); font-size: 1.05rem; font-weight: 500; color: var(--color-ink); white-space: nowrap; letter-spacing: 0.01em;">
      <Sprig size={20} class="nav-sprig" style="color: var(--color-mid); opacity: 0.85; flex-shrink: 0;" />
      River Williams Psychotherapy
    </a>

    <div style="display: flex; align-items: center; gap: 2rem; flex-wrap: wrap;">
      {navLinks.map(link => (
        <a
          href={link.href}
          style={`
            font-family: var(--font-body);
            font-size: 0.8rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: ${currentPath.startsWith(link.href) ? 'var(--color-mid)' : 'var(--color-stone)'};
            transition: color 0.15s;
            ${currentPath.startsWith(link.href) ? 'text-decoration: underline; text-underline-offset: 4px;' : ''}
          `}
        >
          {link.label}
        </a>
      ))}

    </div>

  </nav>
</header>

<style>
  .nav-sprig {
    color: var(--color-mid);
    opacity: 0.85;
    flex-shrink: 0;
  }
</style>
