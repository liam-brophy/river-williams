---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="w-full py-5 px-6 md:px-12 bg-cream border-b border-sand">
  <nav class="max-w-5xl mx-auto flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <a href="/" class="font-serif text-forest text-lg font-medium tracking-wide hover:opacity-80 transition-opacity">
      River Williams Psychotherapy
    </a>
    <ul class="flex flex-wrap gap-6 sm:gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`font-sans text-sm tracking-wide transition-colors duration-200 ${
              currentPath === link.href
                ? 'text-terracotta font-medium'
                : 'text-slate hover:text-forest'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
