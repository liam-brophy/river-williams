---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Reach out to River Williams Psychotherapy to ask questions or schedule a consultation."
>
  <div class="max-w-4xl mx-auto px-6 md:px-12 py-16">
    <header class="mb-12">
      <p class="font-sans text-muted text-sm tracking-widest uppercase mb-3">Reach out</p>
      <h1 class="font-serif text-forest text-4xl md:text-5xl font-medium mb-5">Get in Touch</h1>
      <p class="font-sans text-slate text-base leading-relaxed max-w-xl">
        Reach out to ask questions, inquire about availability, or schedule a free consultation.
        All messages are responded to within 2–3 business days.
      </p>
    </header>

    <div class="grid md:grid-cols-2 gap-14">

      <!-- Contact form -->
      <!-- PLACEHOLDER: Confirm Netlify form is wired up correctly after first deploy — test submission in Netlify dashboard -->
      <div>
        <h2 class="font-serif text-forest text-2xl font-medium mb-6">Send a message</h2>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          action="/thank-you"
          class="space-y-6"
        >
          <input type="hidden" name="form-name" value="contact" />

          <div>
            <label for="name" class="block font-sans text-sm font-medium text-forest mb-2">
              Full name <span class="text-terracotta">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 bg-white border border-sand rounded-xl font-sans text-sm text-slate focus:outline-none focus:border-forest transition-colors"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="block font-sans text-sm font-medium text-forest mb-2">
              Email address <span class="text-terracotta">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 bg-white border border-sand rounded-xl font-sans text-sm text-slate focus:outline-none focus:border-forest transition-colors"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="message" class="block font-sans text-sm font-medium text-forest mb-2">
              Message <span class="text-terracotta">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              class="w-full px-4 py-3 bg-white border border-sand rounded-xl font-sans text-sm text-slate focus:outline-none focus:border-forest transition-colors resize-none"
              placeholder="What brings you here? Feel free to share as much or as little as you'd like."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-3 bg-forest text-cream font-sans font-medium text-sm tracking-wide rounded-full transition-all duration-200 hover:bg-opacity-90"
          >
            Send message
          </button>

          <p class="font-sans text-xs text-muted leading-relaxed">
            This form does not collect health or clinical information. Please do not include
            details about your mental health history in this message.
          </p>
        </form>
      </div>

      <!-- SimplePractice widget + direct info -->
      <div>
        <h2 class="font-serif text-forest text-2xl font-medium mb-4">Schedule directly</h2>
        <p class="font-sans text-slate text-sm leading-relaxed mb-8">
          Existing clients and new inquiries can use the booking portal below to view availability
          and request appointments.
        </p>

        <!-- PLACEHOLDER: Replace this comment block with the SimplePractice embed snippet when available -->
        <!-- SimplePractice widget goes here — paste the <script> or <iframe> snippet provided by SimplePractice -->
        <div class="bg-sand rounded-2xl p-8 text-center">
          <p class="font-serif text-forest text-lg mb-2">Booking portal</p>
          <p class="font-sans text-sm text-muted">SimplePractice scheduling widget will appear here.</p>
        </div>

        <!-- PLACEHOLDER: Update with actual contact details -->
        <div class="mt-8 space-y-3 font-sans text-sm text-slate">
          <p><span class="font-medium text-forest">Email:</span> hello@riverwilliamstherapy.com</p>
          <p><span class="font-medium text-forest">Phone:</span> (000) 000-0000</p>
          <p class="text-xs text-muted leading-relaxed pt-2">
            Phone and email are not monitored in real time. Please do not use these for crisis
            situations — if you are in crisis, call or text 988 or go to your nearest emergency room.
          </p>
        </div>
      </div>

    </div>
  </div>
</Layout>
