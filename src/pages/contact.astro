---
import Layout from '../layouts/Layout.astro';
import Leaf from '../components/icons/Leaf.astro';
import Flower from '../components/icons/Flower.astro';
---

<Layout
  title="Contact"
  description="Get in touch with River Williams Psychotherapy. Book a free 20-minute consultation or send a message."
>

  <div class="max-w-6xl mx-auto px-6 md:px-10 pt-14">

    <!-- Header -->
    <div style="margin-bottom: 3.5rem;">
      <p class="section-label" style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.45rem;">
        <Flower size={11} style="color: var(--color-mid);" />
        Reach out
      </p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2.2rem, 4vw, 3.5rem); font-weight: 700; font-style: normal; color: var(--color-ink); line-height: 1.1; margin-bottom: 1.25rem;">
        Get in Touch
      </h1>
      <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-stone); line-height: 1.75; max-width: 52ch;">
        Reach out to ask questions, inquire about availability, or schedule a free 20-minute consultation. All messages are responded to within 2–3 business days.
      </p>
    </div>

    <div class="rule" style="margin-bottom: 3.5rem;"></div>

    <!-- Two-column: form + direct contact / booking -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; padding-bottom: 6rem;" class="contact-grid">

      <!-- Contact form -->
      <div>
        <p style="font-family: var(--font-display); font-size: 1.4rem; font-weight: 700; font-style: normal; color: var(--color-ink); margin-bottom: 2.5rem;">
          Send a message
        </p>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          action="/thank-you"
          style="display: flex; flex-direction: column; gap: 2.5rem;"
        >
          <input type="hidden" name="form-name" value="contact" />

          <div>
            <label for="name">Full name <span style="color: var(--color-mid);">*</span></label>
            <input type="text" id="name" name="name" required placeholder="Your name" />
          </div>

          <div>
            <label for="email">Email address <span style="color: var(--color-mid);">*</span></label>
            <input type="email" id="email" name="email" required placeholder="you@example.com" />
          </div>

          <div>
            <label for="message">Message <span style="color: var(--color-mid);">*</span></label>
            <textarea id="message" name="message" required rows="6" placeholder="What brings you here? Feel free to share as much or as little as you'd like."></textarea>
          </div>

          <div>
            <button type="submit" class="btn btn-filled" style="font-size: 0.75rem; width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.45rem; padding: 0.85rem 1.5rem;">
              <Leaf size={13} />
              Send message
            </button>
            <p style="font-family: var(--font-body); font-size: 0.78rem; color: var(--color-stone); margin-top: 0.85rem; line-height: 1.6;">
              Please do not include health or clinical information in this form. For crisis support, call or text 988.
            </p>
          </div>

        </form>
      </div>

      <!-- Right: direct contact + SimplePractice -->
      <div style="display: flex; flex-direction: column; gap: 3rem;">

        <!-- Direct contact -->
        <div style="border-top: 0.5px solid var(--color-mid); padding-top: 1.5rem;">
          <p class="section-label" style="margin-bottom: 1.25rem;">Direct contact</p>
          <div style="display: flex; flex-direction: column; gap: 0.6rem;">
            <a href="tel:4848419201" style="font-family: var(--font-display); font-size: 1.15rem; color: var(--color-mid);">
              (484) 841-9201
            </a>
            <a href="mailto:Riverwilliamspsychotherapy@proton.me" style="font-family: var(--font-body); font-size: 0.9rem; color: var(--color-stone); text-decoration: underline; text-underline-offset: 3px; word-break: break-all;">
              Riverwilliamspsychotherapy@proton.me
            </a>
          </div>
          <p style="font-family: var(--font-body); font-size: 0.78rem; color: var(--color-stone); margin-top: 1rem; line-height: 1.6; opacity: 0.8;">
            Phone and email are not monitored in real time.
          </p>
        </div>

        <!-- Free consultation note -->
        <div style="border-top: 0.5px solid var(--color-mid); padding-top: 1.5rem;">
          <p class="section-label" style="margin-bottom: 0.75rem;">Free consultation</p>
          <p style="font-family: var(--font-body); font-size: 0.95rem; color: var(--color-stone); line-height: 1.75;">
            River offers a free 20-minute phone or video consultation for new clients — no commitment required. Use the form or booking portal to request one.
          </p>
        </div>

        <!-- Profile links -->
        <div style="border-top: 0.5px solid var(--color-mid); padding-top: 1.5rem;">
          <p class="section-label" style="margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.45rem;">
            <Flower size={11} style="color: var(--color-mid);" />
            Find River online
          </p>
          <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            <a
              href="https://www.psychologytoday.com/us/therapists/river-joshua-williams-philadelphia-pa/1695729"
              target="_blank"
              rel="noopener noreferrer"
              class="btn"
              style="font-size: 0.72rem; display: inline-flex; align-items: center; gap: 0.5rem; width: fit-content;"
            >
              <Leaf size={12} />
              Psychology Today Profile
            </a>
            <a
              href="https://www.linkedin.com/in/river-joshua-williams-lcsw-mss-cctp-775bb438/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn"
              style="font-size: 0.72rem; display: inline-flex; align-items: center; gap: 0.5rem; width: fit-content;"
            >
              <Leaf size={12} />
              LinkedIn
            </a>
          </div>
        </div>

        <!-- SimplePractice booking widget -->
        <div style="border-top: 0.5px solid var(--color-mid); padding-top: 1.5rem;">
          <p class="section-label" style="margin-bottom: 0.75rem;">Schedule directly</p>
          <p style="font-family: var(--font-body); font-size: 0.88rem; color: var(--color-stone); line-height: 1.7; margin-bottom: 1.5rem;">
            Existing clients and new inquiries can use the booking portal to view availability and request appointments.
          </p>

          <a href="/contact" class="btn" style="font-size: 0.72rem; display: inline-flex; align-items: center; gap: 0.5rem;">
            Request an appointment via form
          </a>
        </div>

      </div>

    </div>
  </div>

</Layout>

<style>
  @media (max-width: 700px) {
    .contact-grid {
      grid-template-columns: 1fr !important;
      gap: 3rem !important;
    }
  }
</style>
