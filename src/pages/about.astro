---
import Layout from '../layouts/Layout.astro';
import CTABlock from '../components/CTABlock.astro';
import Leaf from '../components/icons/Leaf.astro';
import Flower from '../components/icons/Flower.astro';
---

<Layout
  title="About River"
  description="About River Williams, LCSW — licensed psychotherapist in Philadelphia specializing in somatic therapy, EMDR, IFS, and trauma-informed care."
>

  <!-- Page header with headshot -->
  <div style="border-bottom: 0.5px solid var(--color-mid);">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0;" class="about-header">

        <!-- Left: page title -->
        <div style="padding: 4rem 3rem 4rem 0; border-right: 0.5px solid var(--color-mid); display: flex; flex-direction: column; justify-content: flex-end;">
          <p class="section-label" style="margin-bottom: 1rem;">About</p>
          <h1 style="font-family: var(--font-display); font-size: clamp(2.8rem, 5vw, 4.5rem); font-weight: 700; font-style: normal; color: var(--color-ink); line-height: 1.05;">
            About River
          </h1>
          <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-stone); margin-top: 1.5rem; line-height: 1.75; max-width: 38ch;">
            Philadelphia-based LCSW specializing in somatic, EMDR, and trauma-focused psychotherapy.
          </p>
        </div>

        <!-- Right: headshot — duotone via CSS -->
        <div class="botanical-wrapper" style="max-height: 480px;">
          <img
            src="/images/river-headshot.png"
            alt="River Williams, LCSW"
            class="botanical-img"
            style="object-fit: cover; object-position: center top; max-height: 480px;"
          />
        </div>

      </div>
    </div>
  </div>

  <!-- Bio + credentials -->
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-16">
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 5rem;" class="about-body">

      <!-- Main bio -->
      <div>
        <div style="display: flex; flex-direction: column; gap: 1.6rem; font-family: var(--font-body); font-size: 1.05rem; line-height: 1.85; color: var(--color-stone);">

          <p>
            My work is rooted in somatic trauma specialization, curiosity, and trust in each person's innate wisdom. I emphasize creating internal safety and flexibility rather than pushing for change, allowing healing to unfold at a pace the body and internal world can sustain.
          </p>

          <p>
            I am trained in DBT, Internal Family Systems, Psychodynamics, Attachment-Focused EMDR, Mindfulness-Based Stress Reduction, and Somatic Experiencing. I draw additional grounding from spiritual care and counseling, ancestral connection, and ritual. These modalities support clients in processing trauma, working with protective and wounded parts, and developing greater emotional regulation and resilience. Sessions are collaborative, attuned, and paced with careful attention to consent and the nervous system.
          </p>

          <p>
            For over ten years I have lived, studied, and practiced mindfulness and Buddhist traditions, and am trained as a Kripalu 200-hour Yoga teacher. This embodied foundation informs a steady, compassionate therapeutic presence — supporting clients in reconnecting with their bodies, cultivating internal trust, and creating meaningful, lasting change.
          </p>

        </div>

        <!-- Lemon balm botanical — secondary image, duotone via CSS -->
        <div style="margin-top: 3.5rem; border-top: 0.5px solid var(--color-mid); padding-top: 2rem;">
          <div class="botanical-wrapper">
            <img
              src="/images/lemon-balm.avif"
              alt="Lemon balm"
              class="botanical-img"
              style="max-height: 320px; object-fit: cover;"
            />
          </div>
        </div>
      </div>

      <!-- Credentials sidebar -->
      <aside>
        <div style="position: sticky; top: 2rem;">

          <div style="border-top: 0.5px solid var(--color-mid); padding-top: 1.5rem; margin-bottom: 2.5rem;">
            <p class="section-label" style="margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.45rem;">
              <Flower size={11} style="color: var(--color-mid);" />
              Training &amp; Credentials
            </p>
            <ul style="display: flex; flex-direction: column; gap: 0.85rem; list-style: none; padding: 0; margin: 0;">
              {[
                'Licensed Clinical Social Worker (LCSW)',
                'Attachment-Focused EMDR',
                'Somatic Experiencing',
                'Internal Family Systems (IFS)',
                'Dialectical Behavior Therapy (DBT)',
                'Mindfulness-Based Stress Reduction',
                'Psychodynamic orientation',
                'Spiritual care and counseling',
                'Kripalu 200-hr Yoga teacher',
              ].map(item => (
                <li style="display: flex; align-items: center; gap: 0.6rem; font-family: var(--font-body); font-size: 0.9rem; color: var(--color-stone); line-height: 1.5;">
                  <span style="color: var(--color-mid); flex-shrink: 0; opacity: 0.8;"><Leaf size={13} /></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div style="border-top: 0.5px solid var(--color-mid); padding-top: 1.5rem;">
            <p class="section-label" style="margin-bottom: 0.5rem;">Licensure</p>
            <p style="font-family: var(--font-body); font-size: 0.88rem; color: var(--color-stone); line-height: 1.6;">
              Pennsylvania LCSW<br />
              License #CW026881
            </p>
          </div>

        </div>
      </aside>

    </div>
  </div>

  <CTABlock
    heading="Want to work together?"
    body="Schedule a free 20-minute consultation to ask questions, share what's bringing you in, and see if it feels like a good fit."
    primaryLabel="Book Free Consultation"
    primaryHref="/contact"
    secondaryLabel="View services"
    secondaryHref="/services"
  />

</Layout>

<style>
  @media (max-width: 700px) {
    .about-header, .about-body {
      grid-template-columns: 1fr !important;
    }
    .about-header > *:first-child {
      border-right: none !important;
      padding-right: 0 !important;
      padding-bottom: 2rem;
      border-bottom: 0.5px solid var(--color-mid);
    }
  }
</style>
