---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Message Sent"
  description="Thank you for reaching out to River Williams Psychotherapy."
>
  <div class="max-w-2xl mx-auto px-6 py-32 text-center">
    <div class="w-12 h-px bg-terracotta mx-auto mb-10"></div>
    <h1 class="font-serif text-forest text-4xl font-medium mb-5">Thank you for reaching out.</h1>
    <p class="font-sans text-slate text-base leading-relaxed mb-10">
      Your message has been received. River typically responds within 2–3 business days.
      In the meantime, feel free to explore more about the practice.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/" class="btn-primary">Back to home</a>
      <a href="/services" class="btn-secondary">View services</a>
    </div>
  </div>
</Layout>
